{
  "name": "siza-webapp",
  "version": "0.49.1",
  "private": true,
  "license": "MIT",
  "description": "The open full-stack AI workspace — generate, integrate, ship",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "admin:grant": "node --experimental-strip-types scripts/grant-admin-by-email.ts",
    "mcp:playwright:wrapper": "node scripts/playwright-mcp-wrapper.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "lint:shell": "shellcheck --rcfile=.shellcheckrc $(find . -name '*.sh' ! -path '*/node_modules/*') 2>/dev/null || true",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "sync:golden-paths": "npm --workspace @siza/web run sync:golden-paths",
    "sync:skills": "npm --workspace @siza/web run sync:skills",
    "deps:check": "ncu",
    "deps:update": "ncu -u && npm install",
    "deps:unused": "knip",
    "routes:check": "tsx scripts/check-route-coverage.ts",
    "routes:scaffold": "tsx scripts/scaffold-route-test.ts",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "packages/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@forgespace/core": "^1.13.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^5.87.0",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.7.0",
    "wrangler": "^4.74.0"
  },
  "overrides": {
    "dompurify": "^3.3.2",
    "flatted": "^3.4.0",
    "tar": "^7.5.11",
    "onnxruntime-node": {
      "tar": "^7.5.11"
    },
    "undici": "^7.24.3",
    "yauzl": "^3.2.1"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@react-email/components": "^1.0.9",
    "@supabase/supabase-js": "^2.99.2"
  }
}

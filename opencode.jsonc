{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["CLAUDE.md", "AGENTS.md"],
  "mcp": {
    "supabase": {
      "enabled": true
    },
    "vercel": {
      "enabled": true
    },
    "sentry": {
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.next/**",
      "**/.turbo/**",
      "**/coverage/**",
      ".worktrees/**",
      ".serena/**/logs/**"
    ]
  }
}
